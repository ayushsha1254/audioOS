// Secrets.xcconfig.example — copy to Secrets.xcconfig and fill in real values
// Get these from: https://app.supabase.com/project/<your-project>/settings/api
//
// IMPORTANT: xcconfig uses // as a comment delimiter, so full URLs cannot be stored
// as values directly. Store only the host (without https://) here; Info.plist
// prepends "https://" automatically via the SUPABASE_URL key.
SUPABASE_HOST = your-project-ref.supabase.co
SUPABASE_ANON_KEY = your-anon-key-here
